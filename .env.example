# ============================================================
# REBREW BACKEND — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ── MongoDB Atlas ─────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rebrew?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here_minimum_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_very_long_random_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d
JWT_COOKIE_EXPIRES_IN=7

# ── bcrypt ────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Razorpay ──────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret: Dashboard → Webhooks → your endpoint → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Cloudinary ────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=rebrew

# ── Email (Nodemailer / SMTP) ─────────────────────────────────
# For Hostinger: use their SMTP settings
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hello@rebrew.in
SMTP_PASS=your_email_password
EMAIL_FROM=hello@rebrew.in
EMAIL_FROM_NAME=ReBrew

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://rebrew.in,https://www.rebrew.in

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@rebrew.in


# ── WhatsApp Notifications (Interakt) ──────────────────
# Provider: https://interakt.ai (Official WhatsApp Business API)
# Get API key from: Interakt Dashboard → Settings → Developer Settings → API Key
INTERAKT_API_KEY=your_interakt_api_key_here
# Admin mobile number to receive notifications (digits only, no +91 prefix)
ADMIN_WHATSAPP_NUMBER=9876543210

# ── App URL ───────────────────────────────────────────────────
FRONTEND_URL=https://rebrew.in
BACKEND_URL=https://api.rebrew.in
